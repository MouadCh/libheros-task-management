NODE_ENV=development
APP_HOST=localhost
POSTGRES_USER=libheros
POSTGRES_PASSWORD=libheros
POSTGRES_DB=libheros

# Local Bun/Prisma use localhost. Compose overrides the API service to host `postgres`.
# Prefer URL-safe characters in POSTGRES_PASSWORD when Compose builds DATABASE_URL.
DATABASE_URL=postgresql://libheros:libheros@localhost:5432/libheros?schema=public

API_PORT=3001
WEB_PORT=3000

FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NUXT_PUBLIC_WS_URL=http://localhost:3001

# Dev-only placeholders — replace for any shared or production environment.
JWT_ACCESS_SECRET=dev-access-secret-change-me-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32chars
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
