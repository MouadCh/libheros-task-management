NODE_ENV=development
APP_HOST=localhost
API_PORT=3001
WEB_PORT=3000
DATABASE_URL=postgresql://libheros:libheros@localhost:5432/libheros?schema=public
# FRONTEND_ORIGIN and CORS_ORIGINS are derived from APP_HOST + WEB_PORT when omitted
JWT_ACCESS_SECRET=dev-access-secret-change-me-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32chars
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
